{
  "name": "react-boilerplate",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "start": "cross-env VITE_ENV=dev vite",
    "start:backend": "json-server --watch db.json --port 5000 --delay 1000",
    "typegen": "npx openapicmd typegen ./src/apis/api.yml > src/apis/api.d.ts && prettier --write ./src/apis/api.d.ts",
    "build": "npm run typegen && tsc && cross-env VITE_ENV=prod vite build",
    "preview": "vite preview",
    "test": "cross-env VITE_ENV=test vitest",
    "test:updateSnapshots": "cross-env VITE_ENV=test vitest --update",
    "test:coverage": "cross-env VITE_ENV=test vitest run --coverage",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "format": "prettier --write .",
    "lint": "eslint .",
    "type-check": "tsc"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.8",
    "@mui/material": "7.3.8",
    "@mui/x-date-pickers": "8.27.2",
    "@reduxjs/toolkit": "2.11.2",
    "ag-grid-community": "35.1.0",
    "ag-grid-react": "35.1.0",
    "axios": "1.13.6",
    "date-fns": "4.1.0",
    "formik": "2.4.9",
    "i18next": "25.8.13",
    "js-yaml": "4.1.1",
    "notistack": "3.0.2",
    "openapi-client-axios": "7.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.4",
    "react-redux": "9.2.0",
    "react-router-dom": "7.13.1",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "18.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "cross-env": "10.1.0",
    "cypress": "15.11.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-react-app": "7.0.1",
    "eslint-plugin-prettier": "5.5.5",
    "jsdom": "28.1.0",
    "json-server": "0.17.4",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-eslint": "1.8.1",
    "vitest": "4.0.18"
  }
}
