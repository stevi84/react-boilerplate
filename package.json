{
  "name": "react-boilerplate",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "start": "cross-env VITE_ENV=dev vite",
    "start:backend": "node mock-api/server.js",
    "typegen": "npx openapicmd typegen ./src/apis/api.yml > src/apis/api.d.ts && prettier --write ./src/apis/api.d.ts",
    "build": "yarn run typegen && tsc && eslint . && cross-env VITE_ENV=prod vite build",
    "preview": "vite preview",
    "test": "cross-env VITE_ENV=test vitest",
    "test:coverage": "cross-env VITE_ENV=test vitest run --coverage",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "format": "prettier --write .",
    "lint": "eslint .",
    "type-check": "tsc"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.0.0",
    "@mui/material": "9.0.0",
    "@mui/x-date-pickers": "9.0.2",
    "@reduxjs/toolkit": "2.11.2",
    "ag-grid-community": "35.2.1",
    "ag-grid-react": "35.2.1",
    "axios": "1.15.1",
    "date-fns": "4.1.0",
    "formik": "2.4.9",
    "i18next": "26.0.6",
    "js-yaml": "4.1.1",
    "notistack": "3.0.2",
    "openapi-client-axios": "7.9.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "17.0.4",
    "react-redux": "9.2.0",
    "react-router-dom": "7.14.1",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "4.2.3",
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "connect-api-mocker": "1.11.0",
    "cors": "2.8.6",
    "cross-env": "10.1.0",
    "cypress": "15.14.0",
    "eslint": "10.2.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "express": "5.2.1",
    "jsdom": "29.0.2",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "dependenciesMeta": {
    "cypress": {
      "built": true
    }
  }
}
